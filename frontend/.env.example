# API: en dev usa proxy /api. En prod usa backend en Render
# Dev: VITE_API_URL=/api (o omitir)
# Prod: VITE_API_URL=https://bacekend.onrender.com/api
VITE_API_URL=/api

# Supabase Auth (REQUERIDO para login)
# Mismos valores que backend/.env: SUPABASE_URL y SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
