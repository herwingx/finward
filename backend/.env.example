# =============================================================================
# Finward Backend - Variables de Entorno
# =============================================================================
# Copia: cp .env.example .env
# Fuente: Supabase (Cloud o Self-Hosted) - ver mapeo abajo
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Self-hosted - Mapear desde .env del proyecto Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Base de datos - Self-hosted + Tailscale (192.168.100.109)
# -----------------------------------------------------------------------------
# DATABASE_URL: dominio público (producción). DIRECT_URL: IP Tailscale (local).
# Si en local el dominio no resuelve, añade: USE_DIRECT_URL=true
DATABASE_URL="postgresql://postgres:[PASS]@supabase.example.com:5433/postgres"
DIRECT_URL="postgresql://postgres:[PASS]@192.168.100.109:5433/postgres"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS y Frontend (para recuperación de contraseña)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# URL del frontend (para el redirect del email de recuperación)
# FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
ENABLE_CRON_JOBS=false

# -----------------------------------------------------------------------------
# CoinGecko (opcional - precios crypto para inversiones)
# -----------------------------------------------------------------------------
# Sin key: API pública ~30 calls/min.
# Demo API (gratis): COINGECKO_DEMO_API=true + COINGECKO_API_KEY=CG-xxxxx
# Pro API (pago): COINGECKO_API_KEY sin COINGECKO_DEMO_API
# Obtener en https://www.coingecko.com/en/api/pricing
# COINGECKO_DEMO_API=true
# COINGECKO_API_KEY=cg_xxxxx

# -----------------------------------------------------------------------------
# Seed (solo desarrollo)
# -----------------------------------------------------------------------------
# UUID de usuario en Supabase Auth para npm run db:seed
# SEED_USER_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Email (opcional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Finward <noreply@example.com>

# =============================================================================
# MAPEO desde Supabase Self-Hosted .env (Tailscale 192.168.100.109)
# SUPABASE_URL <- SUPABASE_PUBLIC_URL
# SUPABASE_ANON_KEY <- ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY <- SERVICE_ROLE_KEY
# DATABASE_URL <- pooler :6543
# DIRECT_URL <- direct :5433 (evita pooler en 5432)
# =============================================================================
