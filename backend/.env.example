# =============================================================================
# Finward Backend - Variables de Entorno
# =============================================================================
# Copia: cp .env.example .env
# Fuente: Supabase (Cloud o Self-Hosted) - ver mapeo abajo
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase - Copiar desde tu proyecto Supabase
# -----------------------------------------------------------------------------
# Self-hosted: SUPABASE_PUBLIC_URL -> SUPABASE_URL
# Cloud: Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Base de datos (Prisma) - Copiar/derivar desde Supabase
# -----------------------------------------------------------------------------
# Self-hosted - Pooler (Supavisor, puerto 6543):
#   postgresql://postgres.[POOLER_TENANT_ID]:[POSTGRES_PASSWORD]@[SUPABASE_HOST]:6543/postgres?pgbouncer=true
# Self-hosted - Direct (para db push/migrate). Usar 5433 si 5432 es el pooler.
# Tailscale: postgresql://postgres:[PASS]@192.168.100.109:5433/postgres
#
# Cloud - Pooler:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Cloud - Direct:
#   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.tenant:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@192.168.100.109:5433/postgres"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
ENABLE_CRON_JOBS=false

# -----------------------------------------------------------------------------
# Seed (solo desarrollo)
# -----------------------------------------------------------------------------
# UUID de usuario en Supabase Auth para npm run db:seed
# SEED_USER_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Email (opcional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Finward <noreply@example.com>

# =============================================================================
# MAPEO desde Supabase Self-Hosted .env (Tailscale: host 192.168.100.109)
# =============================================================================
# SUPABASE_URL          <- SUPABASE_PUBLIC_URL
# SUPABASE_ANON_KEY     <- ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY <- SERVICE_ROLE_KEY
# DATABASE_URL          <- postgresql://postgres.[POOLER_TENANT_ID]:[POSTGRES_PASSWORD]@192.168.100.109:6543/postgres?pgbouncer=true
# DIRECT_URL            <- postgresql://postgres:[POSTGRES_PASSWORD]@192.168.100.109:5433/postgres
#                       (5433 = Postgres direct, evita conflicto con pooler en 5432)
# =============================================================================
