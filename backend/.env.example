# =============================================================================
# Finward Backend - Variables de Entorno
# =============================================================================
# Copia: cp .env.example .env
# Fuente: Supabase (Cloud o Self-Hosted) - ver mapeo abajo
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Self-hosted - Mapear desde .env del proyecto Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Base de datos - Self-hosted + Tailscale (192.168.100.109)
# -----------------------------------------------------------------------------
# Pooler 6543, Direct 5433 (5432 es pooler)
DATABASE_URL="postgresql://postgres.[TENANT]:[PASS]@192.168.100.109:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASS]@192.168.100.109:5433/postgres"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
ENABLE_CRON_JOBS=false

# -----------------------------------------------------------------------------
# Seed (solo desarrollo)
# -----------------------------------------------------------------------------
# UUID de usuario en Supabase Auth para npm run db:seed
# SEED_USER_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Email (opcional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Finward <noreply@example.com>

# =============================================================================
# MAPEO desde Supabase Self-Hosted .env (Tailscale 192.168.100.109)
# SUPABASE_URL <- SUPABASE_PUBLIC_URL
# SUPABASE_ANON_KEY <- ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY <- SERVICE_ROLE_KEY
# DATABASE_URL <- pooler :6543
# DIRECT_URL <- direct :5433 (evita pooler en 5432)
# =============================================================================
