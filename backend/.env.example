# =============================================================================
# Finward Backend - Variables de Entorno
# =============================================================================
# Copia: cp .env.example .env
# Supabase: Dashboard > Project Settings > Database
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos (Prisma migrations a Supabase Postgres)
# -----------------------------------------------------------------------------
# Pooler (para app): postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct (para migrations): postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Seguridad
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
REGISTRATION_ENABLED=true

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
ENABLE_CRON_JOBS=false

# -----------------------------------------------------------------------------
# Email (opcional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Finward <noreply@example.com>
