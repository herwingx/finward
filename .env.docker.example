# =============================================================================
# Finward - Variables para Docker Compose
# =============================================================================
# Copia a .env en la raíz del proyecto: cp .env.docker.example .env
# Docker Compose usa estas variables como build-args para el frontend.
# =============================================================================

# API URL (el frontend llama a /api, nginx lo enruta al backend)
VITE_API_URL=/api

# Supabase Auth (REQUERIDO para login)
# Mismos valores que backend/.env
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
