# =============================================================================
# Docker Compose - Variables para build del frontend
# =============================================================================
# Copia a .env en la raíz del proyecto para que docker-compose las use.
# Los valores VITE_SUPABASE_* son los mismos que en backend/.env
#
# cp .env.docker.example .env
# Edita .env con tus valores (SUPABASE_URL y SUPABASE_ANON_KEY de backend/.env)
# =============================================================================

VITE_API_URL=/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
